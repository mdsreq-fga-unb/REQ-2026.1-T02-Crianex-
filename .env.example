# ─────────────────────────────────────────────────────────────────────────────
# Crianex Hub — Template de variáveis de ambiente
# Copie para .env e preencha os valores antes de rodar os serviços
# ─────────────────────────────────────────────────────────────────────────────

#-------------------------PESSOAL
SUPABASE_ACCESS_TOKEN=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local: rode `supabase start` e copie os valores exibidos por `supabase status`
# Remoto: obtenha em https://supabase.com/dashboard → Project Settings → API

PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=
JWT_SECRET=

# ── Backend (Express.js) ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BACKEND_URL=http://localhost:3000

# Origem permitida pelo CORS — dev: localhost:5173, prod: domínio da Crianex
CORS_ORIGIN=http://localhost:5173

# ── Frontend (SvelteKit) ───────────────────────────────────────────────────────
# Variáveis com prefixo PUBLIC_ são expostas no browser — nunca coloque segredos

PUBLIC_API_BASE_URL=http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Máx. 5 submissões de lead por IP a cada 10 min (RNF10)
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=5

# ── Dev only ───────────────────────────────────────────────────────────────────
# Bypass de autenticação admin — NUNCA definir como true em produção
# ADMIN_AUTH_BYPASS=true
